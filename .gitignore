# Radiance .gitignore
# Optimized for Python/ComfyUI Custom Node Development

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# Distribution / Packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
.venv/
env/
ENV/

# --- Testing ---
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
htmlcov/
.pytest_cache/

# --- IDEs / Editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- ComfyUI Specific ---
# Exclude model weights or large local assets if placed in node dir
models/
checkpoints/
loras/
*.ckpt
*.safetensors
*.pt
*.pth
*.bin

# --- Logs & Temp ---
*.log
local_settings.py
db.sqlite3
/output/
/temp/

# --- Security (Double Check) ---
.env
.env.*
secrets.json
*.pem
*.key
