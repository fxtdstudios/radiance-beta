# Radiance .gitignore
# Optimized for Python/ComfyUI Custom Node Development

# --- Python ---
__pycache__/
*.py[cod]
*$py.class

# Distribution / Packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
node_modules/

# Virtual Environments
venv/
.venv/
env/
ENV/

# --- Testing ---
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
htmlcov/
.pytest_cache/
.hypothesis/

# --- IDEs / Editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- ComfyUI Specific ---
# Exclude model weights or large local assets if placed in node dir
models/
checkpoints/
loras/
*.ckpt
*.safetensors
*.pt
*.pth
*.bin

# --- Logs & Temp ---
*.log
*.map
*.tmp
*.temp
local_settings.py
db.sqlite3
core/*.db
/output/
/temp/
/temp_pwn/
/tmp_qa_test/
/tmp_qa_output/
workflows/.versions/
workflows/GENERAL/dashboard_*.rad
workflows/GENERAL/test_*_v*.rad

# --- Security (Double Check) ---
.env
.env.*
secrets.json
*.pem
*.key
*.docx
*.bak
scratch/
# EOF
docs/
!docs/
!docs/*.md
!docs/*.html
!docs/*.css
!docs/*.js
!docs/built-in-nodes/
!docs/built-in-nodes/*.md
!docs/site/
!docs/site/*.html
!docs/site/*.css
!docs/site/*.js

# Local dev-server artifacts
artifacts/
